{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "module": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,
    "outDir": "./build",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
